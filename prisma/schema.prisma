generator client {
  provider     = "prisma-client"
  output       = "../prisma/client"
  moduleFormat = "cjs"
  engineType   = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  password  String?
  createdAt DateTime @updatedAt
}
